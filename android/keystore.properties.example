# Keystore configuration for Streaky release build
# ========================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL!
# Add this file to .gitignore

# Release keystore configuration
storeFile=../keystore.jks
storePassword=YOUR_KEYSTORE_PASSWORD_HERE
keyAlias=streaky-release-key
keyPassword=YOUR_KEY_PASSWORD_HERE

# Debug keystore configuration (optional)
# debugStoreFile=${user.home}/.android/debug.keystore
# debugStorePassword=android
# debugKeyAlias=androiddebugkey
# debugKeyPassword=android
